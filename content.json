    "ctaGhost": "Voir l'Insta",
    "steps": [
      {
        "num": "01",
        "title": "Tu envoies",
        "desc": "Photo, référence, fichier STL, croquis sur un coin de table — tout passe."
      },
      {
        "num": "02",
        "title": "On décide",
        "desc": "On regarde ensemble. Matière, finition, taille, budget. Si c'est non, on le dit franchement."
      },
      {
        "num": "03",
        "title": "On imprime",
        "desc": "Photos pendant le process. Peinture main si tu veux. Une pièce à la fois."
      },
      {
        "num": "04",
        "title": "On livre",
        "desc": "France, Belgique, Suisse. Emballage costaud. Si ça casse en chemin, on refait."
      }
